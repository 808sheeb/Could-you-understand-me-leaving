;   param=value ; assign values to parameters

config_version=5

[application]

config/name="couldyouunderstandmeleaving"
config/description="could you understand me leaving? is a walking-simulator about repetitive patterns and agency"
run/main_scene="uid://df7w7xyrweg3t"
config/features=PackedStringArray("4.5", "Mobile")
config/icon="res://icon.svg"

[autoload]

GlobalMessenger="*res://scripts/interact/globalMessenger.gd"
PSXScreenEffects="*res://addons/psx_visuals-25b9e2655b0a76e8ff6c60d6c98dbc18acf59f0a/scripts/Autoload.gd"

[display]

window/size/viewport_width=1024
window/size/viewport_height=768
window/size/resizable=false
window/stretch/mode="viewport"

[editor_plugins]

