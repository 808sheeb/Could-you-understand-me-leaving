; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="couldyouunderstandmeleaving"
config/description="could you understand me leaving? is a walking simulator about adolescence, agency and finding yourself."
run/main_scene="uid://df7w7xyrweg3t"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

GlobalMessenger="*res://scripts/interact/globalMessenger.gd"
DebugMenu="*uid://cggqb75a8w8r"
Autoload="*uid://u3y0jxl0vtmg"

[display]

window/size/resizable=false
window/size/borderless=true
window/size/extend_to_title=true
window/size/sharp_corners=true
window/size/minimize_disabled=true
window/size/maximize_disabled=true
window/subwindows/embed_subwindows=false
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/csg_mesher/plugin.cfg", "res://addons/debug_menu/plugin.cfg", "res://addons/portals/plugin.cfg", "res://addons/proton_scatter/plugin.cfg", "res://addons/zylann.hterrain/plugin.cfg")

