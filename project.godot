[rendering]

occlusion_culling/jitter_projection=false
textures/canvas_textures/default_texture_filter=2
textures/vram_compression/import_etc2_astc=true
lights_and_shadows/directional_shadow/size=2048
lights_and_shadows/directional_shadow/size.mobile=1024
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=0
lights_and_shadows/positional_shadow/soft_shadow_filter_quality=0
reflections/sky_reflections/roughness_layers=4
reflections/sky_reflections/ggx_samples=16
reflections/sky_reflections/ggx_samples.mobile=8
global_illumination/gi/use_half_resolution=true
textures/default_filters/use_nearest_mipmap_filter=true
textures/default_filters/anisotropic_filtering_level=0
camera/depth_of_field/depth_of_field_bokeh_shape=0
camera/depth_of_field/depth_of_field_bokeh_quality=0
environment/ssao/quality=0
environment/ssao/fadeout_from=35.0
environment/ssil/quality=0
anti_aliasing/screen_space_roughness_limiter/enabled=false
textures/default_filters/texture_mipmap_bias=-0.21099999999999983
occlusion_culling/occlusion_rays_per_thread=300
environment/glow/upscale_mode=0
environment/subsurface_scattering/subsurface_scattering_quality=0
global_illumination/sdfgi/frames_to_converge=0
environment/volumetric_fog/volume_depth=32
environment/volumetric_fog/use_filter=0
mesh_lod/lod_change/threshold_pixels=4.0
environment/screen_space_reflection/roughness_quality=0

[shader_globals]

psx_bit_depth={
"type": "int",
"value": 4
}
resolution={
"type": "vec2",
"value": Vector2(1024, 768)
}
color_depth={
"type": "float",
"value": 100.0
}
psx_affine_strength={
"type": "float",
"value": 1.0
}
psx_fog_color={
"type": "color",
"value": Color(0.5, 0.5, 0.5, 0)
}
psx_fog_near={
"type": "float",
"value": 20.0
}
psx_fog_far={
"type": "float",
"value": 10.0
}
psx_snap_size={
"type": "float",
"value": 0.025
}
